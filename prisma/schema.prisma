generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  BANNED
}

model User {
  id                    String                 @id
  name                  String
  email                 String
  emailVerified         Boolean                @default(false)
  image                 String?
  role                  Role                   @default(USER)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  sessions              Session[]
  accounts              Account[]
  noticesCreated        Notice[]               @relation("NoticeCreator")
  noticesRead           UserNotice[]
  transportApplications TransportApplication[]
  filesDocsUploaded     FilesDoc[]
  complaintsSubmitted   Complaint[]            @relation("ComplaintSubmitter")
  complaintsManaged     Complaint[]            @relation("ComplaintManager")

  @@unique([email])
  @@map("user")
}

enum ComplaintType {
  COMPLAINT
  FEEDBACK
  SUGGESTION
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

model Complaint {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation("ComplaintSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  type              ComplaintType    @default(COMPLAINT)
  status            ComplaintStatus  @default(OPEN)
  subject           String
  message           String           @db.Text
  adminResponse     String?          @db.Text
  statusUpdatedAt   DateTime?
  statusUpdatedById String?
  statusUpdatedBy   User?            @relation("ComplaintManager", fields: [statusUpdatedById], references: [id], onDelete: SetNull)
  resolvedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([statusUpdatedById])
  @@map("complaint")
}

model FilesDoc {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  publicId     String   @unique
  url          String
  format       String
  mimeType     String
  bytes        Int
  category     String   @default("General")
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
  @@index([uploadedById])
  @@map("files_doc")
}

model FilesDocCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("files_doc_category")
}

enum NoticeType {
  INFO
  WARNING
  SUCCESS
  DANGER
}

enum NoticeTarget {
  ALL
  ROLE
  SPECIFIC
}

model Notice {
  id          String       @id @default(uuid())
  title       String
  content     String       @db.Text
  type        NoticeType   @default(INFO)
  target      NoticeTarget @default(ALL)
  targetRoles Role[]
  targetUsers String[] // Array of user IDs
  isPublished Boolean      @default(false)
  isPinned    Boolean      @default(false)
  expiryDate  DateTime?
  createdById String
  createdBy   User         @relation("NoticeCreator", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userNotices UserNotice[]

  @@index([createdById])
  @@map("notice")
}

model UserNotice {
  id       String    @id @default(uuid())
  noticeId String
  userId   String
  isRead   Boolean   @default(false)
  readAt   DateTime?
  notice   Notice    @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
  @@index([userId])
  @@map("user_notice")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Route {
  id           String                 @id @default(uuid())
  name         String
  capacity     Int
  startTime    String
  returnTime   String
  isActive     Boolean                @default(true)
  pickupPoints PickupPoint[]
  applications TransportApplication[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@map("route")
}

model PickupPoint {
  id                    String                 @id @default(uuid())
  name                  String
  landmark              String?
  order                 Int
  routeId               String
  route                 Route                  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  transportApplications TransportApplication[]

  @@index([routeId])
  @@map("pickup_point")
}

enum ApplicantType {
  STUDENT
  ACADEMIC
  ADMINISTRATIVE
}

enum ApplicationStatus {
  WAITLIST
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  ROCKET
  BANK_TRANSFER
  CARD
}

model TransportApplication {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  applicantType ApplicantType

  fullName   String
  department String
  batch      String?
  studentId  String?

  phone         String
  phoneVerified Boolean @default(false)

  idCardUrl String

  routeId       String
  route         Route       @relation(fields: [routeId], references: [id])
  pickupPointId String
  pickupPoint   PickupPoint @relation(fields: [pickupPointId], references: [id])

  status ApplicationStatus @default(WAITLIST)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([routeId])
  @@map("transport_application")
}

model Payment {
  id            String               @id @default(cuid())
  applicationId String
  application   TransportApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  semesterId    String?
  semester      Semester?            @relation(fields: [semesterId], references: [id])

  amount   Float
  currency String @default("BDT")

  status PaymentStatus  @default(PENDING)
  method PaymentMethod?

  invoiceId     String? @unique
  invoiceNumber String? @unique
  paymentUrl    String?
  transactionId String?
  reference     String?
  senderNumber  String?

  paidAt      DateTime?
  requestedAt DateTime  @default(now())

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([status])
  @@index([invoiceId])
  @@map("payment")
}

model Semester {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  payments  Payment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("semester")
}
